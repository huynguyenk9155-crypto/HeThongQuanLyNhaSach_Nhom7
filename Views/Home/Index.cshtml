@model IEnumerable<Tuan6.Models.Book>
@using Tuan6.Helpers
@using Tuan6.Models
@{
    ViewData["Title"] = "Trang chủ";
    var categories = ViewBag.Categories as IEnumerable<Tuan6.Models.Category> ?? new List<Category>();
    var selectedCategoryId = ViewBag.SelectedCategoryId as int?;
    var pageNumber = ViewBag.PageNumber as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var wishlistKey = string.IsNullOrEmpty(userId) ? "Wishlist" : $"Wishlist_{userId}";
    var wishlist = Context.Session.GetObjectFromJson<List<WishlistItem>>(wishlistKey) ?? new List<WishlistItem>();

    var categoryIcons = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        { "Văn học", "📚" },
        { "Kinh tế", "📈" },
        { "Khoa học", "🔬" },
        { "Kỹ năng sống", "🌱" },
        { "Lịch sử", "📜" },
        { "Thiếu nhi", "🧸" },
        { "Ngoại ngữ", "🗣️" },
        { "Tâm lý học", "🧠" },
        { "Công nghệ", "💻" },
        { "Nghệ thuật", "🎨" },
        { "Dụng cụ học tập", "✏️" }
    };
}

<main class="user-main">
    <!-- Hero Banner Carousel -->
    @if (selectedCategoryId == null && pageNumber == 1 && string.IsNullOrEmpty(ViewBag.SearchString))
    {
        <div class="hero-slider" id="homeHeroSlider">
            <div class="slider-track" id="sliderTrack">
                <!-- Slide 1: Fahasa Brand Day -->
                <div class="slide slide-fahasa">
                    <div class="slide-content">
                        <span class="slide-badge">⚡ Fahasa Brand Day</span>
                        <h2>HÈ VUI KHÁM PHÁ<br>GIẢM ĐẾN 25%</h2>
                        <p>Bùng nổ ưu đãi cùng bé lớn khôn mỗi ngày. Sách thiếu nhi, văn học, kỹ năng sống đồng loạt giảm sâu!</p>
                        <a href="#bookStoreCatalog" class="btn btn-lg">Mua Sắm Ngay →</a>
                    </div>
                    <div class="slide-image">🏝️</div>
                </div>

                <!-- Slide 2: Lucky Wheel Promo -->
                <div class="slide slide-luckywheel">
                    <div class="slide-content">
                        <span class="slide-badge">🎁 Vòng Quay May Mắn</span>
                        <h2>THỬ VẬN MAY NGAY<br>NHẬN MÃ ĐẾN 50K</h2>
                        <p>Quay bánh xe nhận ngay các coupon độc quyền: LUCKY10, LUCKY20, FREESHIP và nhiều phần quà hấp dẫn!</p>
                        <button type="button" class="btn btn-lg" onclick="openLuckyWheelModal()">Quay Ngay →</button>
                    </div>
                    <div class="slide-image">🎯</div>
                </div>

                <!-- Slide 3: AI Chatbot Assistant Promo -->
                <div class="slide slide-chatbot">
                    <div class="slide-content">
                        <span class="slide-badge">🤖 Trợ Lý Sách AI</span>
                        <h2>TRÒ CHUYỆN CÙNG AI<br>MUA SÁCH TRONG 1 GIÂY</h2>
                        <p>Trợ lý AI hỗ trợ tìm sách thông minh, tự động thêm sách vào giỏ hàng và tặng mã giảm giá độc quyền AIKHACHHANG!</p>
                        <button type="button" class="btn btn-lg" onclick="toggleChatbot()">Trò Chuyện Ngay →</button>
                    </div>
                    <div class="slide-image">🤖</div>
                </div>
            </div>

            <!-- Arrow Controls -->
            <button type="button" class="slider-arrow slider-arrow-prev" id="sliderPrevBtn" aria-label="Slide trước">‹</button>
            <button type="button" class="slider-arrow slider-arrow-next" id="sliderNextBtn" aria-label="Slide tiếp theo">›</button>

            <!-- Dot Indicators -->
            <div class="slider-dots" id="sliderDots">
                <span class="slider-dot active" data-index="0"></span>
                <span class="slider-dot" data-index="1"></span>
                <span class="slider-dot" data-index="2"></span>
            </div>
        </div>
    }


    <div id="bookStoreCatalog" style="margin-bottom: 24px; margin-top: 24px;">
        <h2 style="font-size: 24px; font-weight: 700;">
            @{
                var selectedCat = selectedCategoryId != null ? categories.FirstOrDefault(c => c.Id == selectedCategoryId.Value) : null;
                var displayTitle = selectedCat != null ? selectedCat.Name : "Tất cả sản phẩm";
                var isStationery = selectedCat != null && selectedCat.Name.Equals("Dụng cụ học tập", StringComparison.OrdinalIgnoreCase);
                var unitText = isStationery ? "sản phẩm" : "cuốn sách";
            }
            @displayTitle
        </h2>
        @if (!string.IsNullOrEmpty(ViewBag.SearchString))
        {
            <p style="color: var(--gray-600); font-size: 14px; margin-top: 4px;">Kết quả tìm kiếm cho: <strong>"@ViewBag.SearchString"</strong> (@ViewBag.TotalBooks @unitText)</p>
        }
        else
        {
            <p style="color: var(--gray-600); font-size: 14px; margin-top: 4px;">Tìm thấy <strong>@ViewBag.TotalBooks</strong> @unitText phù hợp</p>
        }
    </div>

    <div class="filter-layout">
        <!-- Filter Sidebar -->
        <aside class="filter-sidebar">
            <h4 style="font-size: 16px; font-weight: 700; margin-bottom: 12px; display: flex; align-items: center; gap: 6px; color: var(--dark);">📂 Thể loại sách</h4>
            <div class="filter-group" style="display: flex; flex-direction: column; gap: 6px; margin-bottom: 24px;">
                <a asp-action="Index" asp-route-categoryId="" asp-route-searchString="@ViewBag.SearchString" 
                   style="display: flex; align-items: center; gap: 8px; font-size: 14px; padding: 8px 12px; border-radius: var(--radius-sm); color: @(selectedCategoryId == null ? "var(--primary)" : "var(--gray-700)"); background: @(selectedCategoryId == null ? "var(--primary-light)" : "transparent"); font-weight: @(selectedCategoryId == null ? "bold" : "normal");">
                    📁 Tất cả sản phẩm
                </a>

                @foreach (var cat in categories.Where(c => !c.Name.Equals("Dụng cụ học tập", StringComparison.OrdinalIgnoreCase)))
                {
                    var icon = categoryIcons.TryGetValue(cat.Name, out var emoji) ? emoji : "📖";
                    <a asp-action="Index" asp-route-categoryId="@cat.Id" asp-route-searchString="@ViewBag.SearchString"
                       style="display: flex; align-items: center; gap: 8px; font-size: 14px; padding: 8px 12px; border-radius: var(--radius-sm); color: @(selectedCategoryId == cat.Id ? "var(--primary)" : "var(--gray-700)"); background: @(selectedCategoryId == cat.Id ? "var(--primary-light)" : "transparent"); font-weight: @(selectedCategoryId == cat.Id ? "bold" : "normal");">
                        @icon @cat.Name
                    </a>
                }
            </div>

            <h4 style="font-size: 16px; font-weight: 700; margin-bottom: 12px; display: flex; align-items: center; gap: 6px; color: var(--dark); border-top: 1px solid var(--gray-200); padding-top: 16px;">✏️ Dụng cụ học tập</h4>
            <div class="filter-group" style="display: flex; flex-direction: column; gap: 6px;">
                @foreach (var cat in categories.Where(c => c.Name.Equals("Dụng cụ học tập", StringComparison.OrdinalIgnoreCase)))
                {
                    var icon = categoryIcons.TryGetValue(cat.Name, out var emoji) ? emoji : "📖";
                    <a asp-action="Index" asp-route-categoryId="@cat.Id" asp-route-searchString="@ViewBag.SearchString"
                       style="display: flex; align-items: center; gap: 8px; font-size: 14px; padding: 8px 12px; border-radius: var(--radius-sm); color: @(selectedCategoryId == cat.Id ? "var(--primary)" : "var(--gray-700)"); background: @(selectedCategoryId == cat.Id ? "var(--primary-light)" : "transparent"); font-weight: @(selectedCategoryId == cat.Id ? "bold" : "normal");">
                        @icon @cat.Name
                    </a>
                }
            </div>
        </aside>

        <!-- Books Grid -->
        <div>
            @if (Model != null && Model.Any())
            {
                <div class="books-grid">
                    @foreach (var book in Model)
                    {
                        <div class="book-card">
                            <div class="book-cover">
                                @if (!string.IsNullOrEmpty(book.ImageUrl))
                                {
                                    <img src="@book.ImageUrl" alt="@book.Title" style="width: 100%; height: 100%; object-fit: contain;" />
                                }
                                else
                                {
                                    <text>📕</text>
                                }
                                
                                @if (book.StockQuantity == 0)
                                {
                                    <span class="book-badge" style="background: var(--dark);">Hết hàng</span>
                                }
                                else if (book.StockQuantity < 10)
                                {
                                    <span class="book-badge" style="background: var(--warning); color: black;">Sắp hết</span>
                                }

                                @{
                                    var isInWishlist = wishlist.Any(w => w.BookId == book.Id);
                                }
                                <button class="book-wishlist" type="button" onclick="toggleWishlist(@book.Id, this)" style="color: @(isInWishlist ? "var(--danger)" : "inherit");">
                                    @(isInWishlist ? "❤️" : "♡")
                                </button>
                            </div>
                            <div class="book-info">
                                <div class="book-title" title="@book.Title">@book.Title</div>
                                <div class="book-author">@book.Author</div>
                                <div class="book-rating">
                                    <span class="stars">★★★★★</span>
                                    <span class="count">(12)</span>
                                </div>
                                <div class="book-price">
                                    <span class="current">@book.Price.ToString("N0")đ</span>
                                </div>
                            </div>
                            <div class="book-actions">
                                @if (book.StockQuantity > 0)
                                {
                                    <form asp-controller="Cart" asp-action="AddToCart" method="post" style="display: contents;">
                                        <input type="hidden" name="bookId" value="@book.Id" />
                                        <button type="submit" class="btn btn-primary btn-sm">🛒 Thêm</button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn btn-secondary btn-sm" disabled style="cursor: not-allowed; opacity: 0.6;">Hết hàng</button>
                                }
                                <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-outline btn-sm">👁 Xem</a>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (totalPages > 1)
                {
                    <div class="pagination" style="justify-content: center; border: none; padding: 24px 0;">
                        <div class="pages" style="display: flex; gap: 8px;">
                            @if (pageNumber > 1)
                            {
                                <a asp-action="Index" asp-route-categoryId="@selectedCategoryId" asp-route-searchString="@ViewBag.SearchString" asp-route-pageNumber="@(pageNumber - 1)" class="btn btn-outline btn-sm" style="display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; padding: 0;">‹</a>
                            }

                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <a asp-action="Index" asp-route-categoryId="@selectedCategoryId" asp-route-searchString="@ViewBag.SearchString" asp-route-pageNumber="@i" 
                                   class="btn btn-sm" 
                                   style="display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; padding: 0; background: @(pageNumber == i ? "var(--primary)" : "transparent"); color: @(pageNumber == i ? "white" : "var(--gray-700)"); border: 2px solid @(pageNumber == i ? "var(--primary)" : "var(--gray-300)"); font-weight: @(pageNumber == i ? "bold" : "normal");">
                                    @i
                                </a>
                            }

                            @if (pageNumber < totalPages)
                            {
                                <a asp-action="Index" asp-route-categoryId="@selectedCategoryId" asp-route-searchString="@ViewBag.SearchString" asp-route-pageNumber="@(pageNumber + 1)" class="btn btn-outline btn-sm" style="display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; padding: 0;">›</a>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: 64px 0; background: white; border-radius: var(--radius-md); box-shadow: var(--shadow);">
                    <div style="font-size: 64px; margin-bottom: 16px;">📂</div>
                    <h3 style="color: var(--gray-600);">Không tìm thấy sách nào</h3>
                    <p style="color: var(--gray-500); margin-top: 8px;">Vui lòng chọn danh mục khác hoặc thay đổi từ khóa tìm kiếm.</p>
                </div>
            }
        </div>
    </div>
</main>

@section Scripts {
    <script>
        function toggleWishlist(bookId, btn) {
            fetch('/Wishlist/Toggle?bookId=' + bookId, {
                method: 'POST'
            })
            .then(response => {
                if (response.redirected) {
                    window.location.href = response.url;
                    return;
                }
                return response.json();
            })
            .then(data => {
                if (data && data.success) {
                    if (data.added) {
                        btn.innerHTML = '❤️';
                        btn.style.color = 'var(--danger)';
                        showToast('success', data.message);
                    } else {
                        btn.innerHTML = '♡';
                        btn.style.color = 'inherit';
                        showToast('info', data.message);
                    }
                    
                    // Update header badge count
                    const headerBtn = document.getElementById('wishlistHeaderBtn');
                    if (headerBtn) {
                        let badge = headerBtn.querySelector('.badge');
                        if (data.count > 0) {
                            if (!badge) {
                                badge = document.createElement('span');
                                badge.className = 'badge';
                                headerBtn.appendChild(badge);
                            }
                            badge.textContent = data.count;
                        } else {
                            if (badge) {
                                badge.remove();
                            }
                        }
                    }
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showToast('error', 'Có lỗi xảy ra. Vui lòng thử lại.');
            });
        }

        // ===== AJAX Catalog Search & Filter =====
        document.addEventListener("DOMContentLoaded", function() {
            const searchInput = document.querySelector('.search-bar input[name="searchString"]');
            const searchForm = document.querySelector('.search-bar');
            const mainContent = document.querySelector('main.user-main');

            if (!searchInput || !mainContent) return;

            let searchTimeout;
            let heroSliderInterval;

            // ===== HERO CAROUSEL / SLIDER LOGIC =====
            function initHeroSlider() {
                // Clear any existing interval first to prevent speed-up bugs
                if (heroSliderInterval) {
                    clearInterval(heroSliderInterval);
                }

                const slider = document.getElementById('homeHeroSlider');
                if (!slider) return;

                const track = document.getElementById('sliderTrack');
                const slides = document.querySelectorAll('.slide');
                const dots = document.querySelectorAll('.slider-dot');
                const prevBtn = document.getElementById('sliderPrevBtn');
                const nextBtn = document.getElementById('sliderNextBtn');

                if (!track || slides.length === 0) return;

                let currentIndex = 0;
                const slideDuration = 5000; // 5 seconds

                function updateSlider() {
                    track.style.transform = `translateX(-${currentIndex * 100}%)`;
                    dots.forEach((dot, index) => {
                        if (index === currentIndex) {
                            dot.classList.add('active');
                        } else {
                            dot.classList.remove('active');
                        }
                    });
                }

                function nextSlide() {
                    currentIndex = (currentIndex + 1) % slides.length;
                    updateSlider();
                }

                function prevSlide() {
                    currentIndex = (currentIndex - 1 + slides.length) % slides.length;
                    updateSlider();
                }

                function goToSlide(index) {
                    currentIndex = index;
                    updateSlider();
                }

                function startAutoSlide() {
                    clearInterval(heroSliderInterval);
                    heroSliderInterval = setInterval(nextSlide, slideDuration);
                }

                function stopAutoSlide() {
                    clearInterval(heroSliderInterval);
                }

                if (prevBtn) {
                    prevBtn.addEventListener('click', function(e) {
                        e.preventDefault();
                        prevSlide();
                        startAutoSlide();
                    });
                }

                if (nextBtn) {
                    nextBtn.addEventListener('click', function(e) {
                        e.preventDefault();
                        nextSlide();
                        startAutoSlide();
                    });
                }

                dots.forEach(dot => {
                    dot.addEventListener('click', function(e) {
                        e.preventDefault();
                        const index = parseInt(dot.getAttribute('data-index'));
                        goToSlide(index);
                        startAutoSlide();
                    });
                });

                slider.addEventListener('mouseenter', stopAutoSlide);
                slider.addEventListener('mouseleave', startAutoSlide);

                // Initial start
                startAutoSlide();
            }

            // Expose CTA triggers to window globally so inline onclick handlers work
            window.openLuckyWheelModal = function() {
                const wheelToggle = document.getElementById('lucky-wheel-toggle');
                if (wheelToggle) {
                    wheelToggle.click();
                }
            };

            window.toggleChatbot = function() {
                const chatbotToggle = document.getElementById('chatbot-toggle');
                if (chatbotToggle) {
                    chatbotToggle.click();
                }
            };

            // Helper to load content via AJAX
            function loadCatalog(url, updateUrlInHistory = true) {
                // Show loading indicator by dimming the main content
                mainContent.style.opacity = '0.5';
                mainContent.style.transition = 'opacity 0.2s ease';

                fetch(url)
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }
                        return response.text();
                    })
                    .then(htmlText => {
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(htmlText, 'text/html');
                        const newMainContent = doc.querySelector('main.user-main');

                        if (newMainContent) {
                            mainContent.innerHTML = newMainContent.innerHTML;
                            initHeroSlider(); // Re-initialize slider on dynamic navigation
                        }

                        mainContent.style.opacity = '1';

                        if (updateUrlInHistory) {
                            history.pushState(null, '', url);
                        }

                        // Keep the search input value in sync with the URL parameter
                        const currentUrl = new URL(url, window.location.origin);
                        const searchParam = currentUrl.searchParams.get('searchString') || '';
                        if (searchInput.value !== searchParam) {
                            searchInput.value = searchParam;
                        }
                    })
                    .catch(error => {
                        console.error('AJAX Load error:', error);
                        mainContent.style.opacity = '1';
                    });
            }

            // Intercept search input keyup/input event for real-time search
            searchInput.addEventListener('input', function(e) {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => {
                    const query = e.target.value;
                    const url = new URL(window.location.href, window.location.origin);
                    url.searchParams.set('searchString', query);
                    url.searchParams.set('pageNumber', '1'); // Reset pagination on new search
                    loadCatalog(url.toString());
                }, 200); // 200ms debounce
            });

            // Intercept form submission to prevent full page reload
            searchForm.addEventListener('submit', function(e) {
                e.preventDefault();
                clearTimeout(searchTimeout);
                const query = searchInput.value;
                const url = new URL(window.location.href, window.location.origin);
                url.searchParams.set('searchString', query);
                url.searchParams.set('pageNumber', '1');
                loadCatalog(url.toString());
            });

            // Intercept category and pagination link clicks
            document.addEventListener('click', function(e) {
                const link = e.target.closest('.filter-sidebar a, .pagination a');
                if (link) {
                    e.preventDefault();
                    loadCatalog(link.href);
                }
            });

            // Handle browser back/forward buttons
            window.addEventListener('popstate', function() {
                loadCatalog(window.location.href, false);
            });

            // Initial call to set up the slider
            initHeroSlider();
        });

    </script>
}
