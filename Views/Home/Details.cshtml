@model Tuan6.Models.Product
@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="card shadow border-0 rounded-3 p-4">
        <div class="row g-5">
            <!-- Left Side: Product Image -->
            <div class="col-md-6 col-lg-5">
                <div class="bg-light rounded border d-flex align-items-center justify-content-center p-3" style="min-height: 400px;">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded" style="max-height: 450px; object-fit: contain;" />
                    }
                    else
                    {
                        <div class="text-center text-muted">
                            <i class="bi bi-image text-muted" style="font-size: 6rem;"></i>
                            <p class="mt-2 mb-0">Không có hình ảnh</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Right Side: Product Details -->
            <div class="col-md-6 col-lg-7">
                <div class="d-flex flex-column h-100">
                    <div>
                        <span class="badge bg-secondary mb-2 px-3 py-2 fs-7">@(Model.Category?.Name ?? "N/A")</span>
                        <h1 class="fw-bold text-dark mb-3">@Model.Name</h1>
                        
                        <div class="fs-2 fw-bold text-success mb-4">@Model.Price.ToString("N0") đ</div>
                        
                        <h5 class="fw-bold text-primary mb-2 border-bottom pb-2">Mô tả sản phẩm</h5>
                        <p class="text-muted lh-base" style="white-space: pre-line;">@Model.Description</p>
                    </div>

                    <div class="mt-auto pt-4 d-flex gap-3 border-top">
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">Quay lại Cửa hàng</a>
                        <button class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm"><i class="bi bi-cart-plus-fill"></i> Thêm vào giỏ hàng</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
