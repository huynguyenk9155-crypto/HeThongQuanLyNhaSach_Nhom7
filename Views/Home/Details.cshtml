@model Tuan6.Models.Book
@{
    ViewData["Title"] = Model.Title;
}

<main class="user-main">
    <div style="margin-bottom: 24px; font-size: 14px; color: var(--gray-600);">
        <a asp-action="Index" style="color: var(--primary);">Trang chủ</a> &rsaquo; 
        <a asp-action="Index" asp-route-categoryId="@Model.CategoryId" style="color: var(--primary);">@(Model.Category?.Name ?? "Thể loại")</a> &rsaquo; 
        <span>@Model.Title</span>
    </div>

    <div class="details-layout" style="background: white; padding: 32px; border-radius: var(--radius-md); box-shadow: var(--shadow);">
        <!-- Bìa sách bên trái -->
        <div style="display: flex; justify-content: center; background: var(--gray-100); padding: 24px; border-radius: var(--radius-md); max-height: 480px; align-items: center; overflow: hidden; box-shadow: var(--shadow-sm);">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Title" style="max-width: 100%; max-height: 400px; object-fit: contain; border-radius: var(--radius-sm); box-shadow: var(--shadow);" />
            }
            else
            {
                <div style="font-size: 120px;">📕</div>
            }
        </div>

        <!-- Thông tin chi tiết bên phải -->
        <div style="display: flex; flex-direction: column; justify-content: space-between;">
            <div>
                <span class="status-badge processing" style="margin-bottom: 12px; font-size: 13px;">@(Model.Category?.Name ?? "N/A")</span>
                <h1 style="font-size: 28px; font-weight: 800; color: var(--dark); margin-bottom: 8px; line-height: 1.3;">@Model.Title</h1>
                <div style="font-size: 16px; color: var(--gray-650); margin-bottom: 8px;">Tác giả: <strong style="color: var(--primary);">@Model.Author</strong></div>
                @if (Model.Publisher != null)
                {
                    <div style="font-size: 14px; color: var(--gray-600); margin-bottom: 20px;">Nhà xuất bản: <strong style="color: var(--dark);">@Model.Publisher.Name</strong></div>
                }
                else
                {
                    <div style="margin-bottom: 20px;"></div>
                }
                
                <div style="font-size: 28px; font-weight: 800; color: var(--danger); margin-bottom: 24px;">@Model.Price.ToString("N0")đ</div>
                
                <div style="background: var(--gray-100); padding: 16px; border-radius: var(--radius); font-size: 14px; margin-bottom: 24px;">
                    <div><strong>Tình trạng kho:</strong> 
                        @if (Model.StockQuantity == 0)
                        {
                            <span class="status-badge cancelled" style="font-size: 12px;">Hết hàng</span>
                        }
                        else if (Model.StockQuantity < 10)
                        {
                            <span class="status-badge pending" style="font-size: 12px;">Sắp hết (Còn @Model.StockQuantity cuốn)</span>
                        }
                        else
                        {
                            <span class="status-badge completed" style="font-size: 12px;">Còn hàng (Còn @Model.StockQuantity cuốn)</span>
                        }
                    </div>
                </div>

                <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 12px; border-bottom: 2px solid var(--gray-200); padding-bottom: 8px; color: var(--gray-800);">📖 Giới thiệu nội dung</h3>
                <p style="font-size: 14px; color: var(--gray-700); line-height: 1.6; text-align: justify; white-space: pre-line; margin-bottom: 24px;">
                    @(string.IsNullOrEmpty(Model.Description) ? "Cuốn sách này chưa có giới thiệu nội dung tóm tắt từ nhà xuất bản." : Model.Description)
                </p>

                @if (Model.AuthorRelation != null && !string.IsNullOrEmpty(Model.AuthorRelation.Biography))
                {
                    <h3 style="font-size: 16px; font-weight: 700; margin-top: 24px; margin-bottom: 12px; border-bottom: 2px solid var(--gray-200); padding-bottom: 8px; color: var(--gray-800);">👤 Vài nét về tác giả</h3>
                    <p style="font-size: 14px; color: var(--gray-600); line-height: 1.6; text-align: justify; margin-bottom: 32px; font-style: italic;">
                        @Model.AuthorRelation.Biography
                    </p>
                }
            </div>

            <div style="display: flex; gap: 16px; align-items: center; border-top: 2px solid var(--gray-200); padding-top: 24px; flex-wrap: wrap;">
                <a asp-action="Index" class="btn btn-outline" style="height: 48px; min-width: 180px; justify-content: center;">← Quay lại cửa hàng</a>
                
                @if (Model.StockQuantity > 0)
                {
                    <form asp-controller="Cart" asp-action="AddToCart" method="post" style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin: 0;">
                        <input type="hidden" name="bookId" value="@Model.Id" />
                        
                        <!-- Số lượng mua -->
                        <div style="display: flex; align-items: center; border: 2px solid var(--gray-300); border-radius: var(--radius); overflow: hidden; height: 48px; background: white;">
                            <button type="button" onclick="decrementQuantity()" style="width: 40px; height: 100%; background: var(--gray-100); font-size: 16px; font-weight: bold; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; outline: none;">−</button>
                            <input type="number" id="purchaseQuantity" name="quantity" value="1" min="1" max="@Model.StockQuantity" readonly style="width: 50px; height: 100%; border: none; text-align: center; font-weight: bold; font-size: 15px; outline: none; background: white;" />
                            <button type="button" onclick="incrementQuantity()" style="width: 40px; height: 100%; background: var(--gray-100); font-size: 16px; font-weight: bold; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; outline: none;">+</button>
                        </div>

                        <button type="submit" class="btn btn-primary" style="height: 48px; min-width: 220px; justify-content: center;">
                            🛒 Thêm vào giỏ hàng
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn btn-secondary" disabled style="height: 48px; min-width: 220px; justify-content: center; cursor: not-allowed; opacity: 0.6;">
                        ❌ Hết hàng tạm thời
                    </button>
                }
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        function decrementQuantity() {
            const input = document.getElementById('purchaseQuantity');
            if (input) {
                let val = parseInt(input.value);
                if (val > 1) {
                    input.value = val - 1;
                }
            }
        }
        function incrementQuantity() {
            const input = document.getElementById('purchaseQuantity');
            if (input) {
                let val = parseInt(input.value);
                const max = parseInt(input.getAttribute('max')) || 1;
                if (val < max) {
                    input.value = val + 1;
                }
            }
        }
    </script>
}
