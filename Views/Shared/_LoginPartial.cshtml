@using Microsoft.AspNetCore.Identity
@using Tuan6.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    var fullName = user?.FullName ?? User.Identity?.Name;
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle text-dark fw-bold" href="#" id="navbarUserDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            Chào, @fullName!
        </a>
        <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="navbarUserDropdown">
            @if (User.IsInRole("Admin"))
            {
                <li><a class="dropdown-item fw-bold text-primary" asp-area="Admin" asp-controller="Book" asp-action="Index">Khu vực Admin</a></li>
                <li><hr class="dropdown-divider"></li>
            }
            <li>
                <form class="form-inline" asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="dropdown-item text-danger">Đăng xuất</button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Register">Đăng ký</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark btn btn-outline-primary px-3 ms-2 rounded-pill" asp-area="" asp-controller="Account" asp-action="Login">Đăng nhập</a>
    </li>
}
</ul>
