@model Tuan6.Models.ForgotPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Quên mật khẩu";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-container">
            <div class="auth-logo">
                <div class="logo-icon">🔑</div>
                <h1>Quên mật khẩu</h1>
                <p>Nhập email của bạn để bắt đầu khôi phục mật khẩu</p>
            </div>

            <form asp-action="ForgotPassword" method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div style="background: #f8d7da; color: #721c24; padding: 12px; border-radius: var(--radius); margin-bottom: 20px; font-size: 14px;">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <div class="form-group">
                    <label asp-for="Email">Địa chỉ Email</label>
                    <input asp-for="Email" type="email" placeholder="example@email.com" required />
                    <span asp-validation-for="Email" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-full btn-lg">
                    Gửi yêu cầu khôi phục
                </button>
            </form>

            <div class="auth-footer" style="margin-top: 30px;">
                Quay lại trang <a asp-action="Login">Đăng nhập</a>
            </div>
        </div>
    </div>
</body>
</html>
