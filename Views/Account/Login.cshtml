@model Tuan6.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-container">
            <div class="auth-logo">
                <div class="logo-icon">📚</div>
                <h1>BookStore</h1>
                <p>Đăng nhập vào tài khoản của bạn</p>
            </div>

            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div style="background: #f8d7da; color: #721c24; padding: 12px; border-radius: var(--radius); margin-bottom: 20px; font-size: 14px;">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <div class="form-group">
                    <label asp-for="UserNameOrEmail">Tên đăng nhập hoặc Email</label>
                    <input asp-for="UserNameOrEmail" placeholder="example@email.com hoặc tên đăng nhập" required />
                    <span asp-validation-for="UserNameOrEmail" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Password">Mật khẩu</label>
                    <input asp-for="Password" type="password" placeholder="Nhập mật khẩu" required />
                    <span asp-validation-for="Password" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>
                <div class="remember-forgot">
                    <label>
                        <input type="checkbox" asp-for="RememberMe"> Ghi nhớ đăng nhập
                    </label>
                    <a href="#">Quên mật khẩu?</a>
                </div>
                <button type="submit" class="btn btn-primary btn-full btn-lg">
                    Đăng nhập
                </button>
            </form>

            <div class="auth-divider"><span>Hoặc đăng nhập với</span></div>

            <div class="social-login">
                <button class="social-btn">🔵 Google</button>
                <button class="social-btn">📘 Facebook</button>
            </div>

            <div class="auth-footer">
                Chưa có tài khoản? <a asp-action="Register">Đăng ký ngay</a>
            </div>
        </div>
    </div>
</body>
</html>
