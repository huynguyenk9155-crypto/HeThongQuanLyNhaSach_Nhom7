@{
    ViewData["Title"] = "Từ chối truy cập";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 text-center py-5">
        <div class="mb-4">
            <i class="bi bi-shield-lock-fill text-danger" style="font-size: 6rem;"></i>
        </div>
        <h1 class="display-4 fw-bold text-danger">Từ chối truy cập</h1>
        <p class="lead text-muted mt-3">Bạn không có quyền truy cập vào chức năng hoặc khu vực quản trị này.</p>
        <hr class="my-4 mx-auto w-25">
        <p class="mb-4 text-muted">Vui lòng đăng nhập bằng tài khoản có quyền Quản trị viên (Admin) để tiếp tục.</p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">Quay lại Trang chủ</a>
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="btn btn-danger btn-lg px-4 rounded-pill">Đăng xuất & Đăng nhập lại</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
