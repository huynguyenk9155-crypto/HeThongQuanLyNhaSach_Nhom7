@{
    Layout = null;
    ViewData["Title"] = "Xác nhận khôi phục";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-container">
            <div class="auth-logo">
                <div class="logo-icon" style="background: rgba(40, 167, 69, 0.1); color: var(--success);">✉️</div>
                <h1 style="color: var(--success); margin-top: 15px;">Đã gửi yêu cầu!</h1>
                <p>Một liên kết đặt lại mật khẩu đã được tạo mô phỏng trong hệ thống.</p>
            </div>

            <div style="background: var(--gray-50); border: 1px dashed var(--gray-300); padding: 16px; border-radius: var(--radius); margin-bottom: 24px; font-size: 14px; text-align: left;">
                <p style="margin: 0 0 10px; font-weight: bold; color: var(--dark);">Mô phỏng Email khôi phục mật khẩu:</p>
                <a href="@TempData["ResetLink"]" style="word-break: break-all; font-weight: 600; color: var(--primary); text-decoration: underline;">
                    @TempData["ResetLink"]
                </a>
            </div>

            <p style="color: var(--gray-500); font-size: 14px; margin-bottom: 24px;">
                Nhấp vào liên kết trên để tiến hành đặt lại mật khẩu của bạn.
            </p>

            <a asp-action="Login" class="btn btn-outline btn-full btn-lg">
                Quay lại Đăng nhập
            </a>
        </div>
    </div>
</body>
</html>
