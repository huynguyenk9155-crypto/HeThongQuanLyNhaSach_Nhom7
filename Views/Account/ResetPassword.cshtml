@model Tuan6.Models.ResetPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đặt lại mật khẩu";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-container">
            <div class="auth-logo">
                <div class="logo-icon">🔒</div>
                <h1>Đặt lại mật khẩu</h1>
                <p>Nhập mật khẩu mới cho tài khoản của bạn</p>
            </div>

            <form asp-action="ResetPassword" method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div style="background: #f8d7da; color: #721c24; padding: 12px; border-radius: var(--radius); margin-bottom: 20px; font-size: 14px;">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Token" />

                <div class="form-group">
                    <label asp-for="Password">Mật khẩu mới</label>
                    <input asp-for="Password" type="password" placeholder="Tối thiểu 4 ký tự" required />
                    <span asp-validation-for="Password" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword">Xác nhận mật khẩu</label>
                    <input asp-for="ConfirmPassword" type="password" placeholder="Nhập lại mật khẩu mới" required />
                    <span asp-validation-for="ConfirmPassword" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-full btn-lg">
                    Đặt lại mật khẩu
                </button>
            </form>
        </div>
    </div>
</body>
</html>
