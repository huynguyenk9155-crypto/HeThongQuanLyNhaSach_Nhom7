@model Tuan6.Models.ProfileViewModel
@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="user-container" style="max-width: 800px; margin: 40px auto; padding: 0 16px;">
    <div style="background: white; border-radius: var(--radius-lg); box-shadow: var(--shadow); padding: 32px; border: 1px solid var(--gray-200);">
        <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid var(--gray-200);">
            <div style="width: 60px; height: 60px; border-radius: 50%; background: var(--primary-light); color: var(--primary); display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: bold;">
                👤
            </div>
            <div>
                <h1 style="font-size: 22px; font-weight: bold; color: var(--dark); margin: 0 0 4px;">Thông tin cá nhân</h1>
                <p style="color: var(--gray-500); margin: 0; font-size: 14px;">Quản lý và cập nhật thông tin cá nhân của bạn</p>
            </div>
        </div>

        <form asp-action="Profile" method="post">
            @if (!ViewData.ModelState.IsValid)
            {
                <div style="background: #f8d7da; color: #721c24; padding: 12px; border-radius: var(--radius); margin-bottom: 20px; font-size: 14px;">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                <div class="form-group">
                    <label asp-for="FullName">Họ và tên</label>
                    <input asp-for="FullName" placeholder="Nhập họ và tên" required style="width: 100%; padding: 10px; border: 1px solid var(--gray-300); border-radius: var(--radius); font-size: 14px;" />
                    <span asp-validation-for="FullName" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email">Địa chỉ Email</label>
                    <input asp-for="Email" type="email" placeholder="example@email.com" required style="width: 100%; padding: 10px; border: 1px solid var(--gray-300); border-radius: var(--radius); font-size: 14px;" />
                    <span asp-validation-for="Email" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                <div class="form-group">
                    <label asp-for="PhoneNumber">Số điện thoại</label>
                    <input asp-for="PhoneNumber" placeholder="Nhập số điện thoại" style="width: 100%; padding: 10px; border: 1px solid var(--gray-300); border-radius: var(--radius); font-size: 14px;" />
                    <span asp-validation-for="PhoneNumber" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Address">Địa chỉ giao hàng</label>
                    <input asp-for="Address" placeholder="Nhập địa chỉ của bạn" style="width: 100%; padding: 10px; border: 1px solid var(--gray-300); border-radius: var(--radius); font-size: 14px;" />
                    <span asp-validation-for="Address" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>
            </div>

            <div style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 30px; padding-top: 20px; border-top: 1px solid var(--gray-200);">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline" style="padding: 10px 24px; border-radius: var(--radius); font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none;">Hủy</a>
                <button type="submit" class="btn btn-primary" style="padding: 10px 24px; border-radius: var(--radius); font-size: 14px; font-weight: 600; cursor: pointer; border: none;">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>
