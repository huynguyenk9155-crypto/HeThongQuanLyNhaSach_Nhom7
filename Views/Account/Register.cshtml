@model Tuan6.Models.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng ký";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-container" style="max-width: 520px;">
            <div class="auth-logo">
                <div class="logo-icon">📚</div>
                <h1>Đăng Ký Tài Khoản</h1>
                <p>Tạo tài khoản mới để trải nghiệm mua sắm</p>
            </div>

            <form asp-action="Register" method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div style="background: #f8d7da; color: #721c24; padding: 12px; border-radius: var(--radius); margin-bottom: 20px; font-size: 14px;">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label asp-for="UserName">Tên đăng nhập *</label>
                        <input asp-for="UserName" placeholder="Ví dụ: nguyenvana" required />
                        <span asp-validation-for="UserName" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label asp-for="FullName">Họ tên *</label>
                        <input asp-for="FullName" placeholder="Ví dụ: Nguyễn Văn A" required />
                        <span asp-validation-for="FullName" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Email">Email *</label>
                    <input asp-for="Email" type="email" placeholder="example@email.com" required />
                    <span asp-validation-for="Email" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Address">Địa chỉ *</label>
                    <input asp-for="Address" placeholder="Nhập địa chỉ của bạn" required />
                    <span asp-validation-for="Address" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>

                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label asp-for="Password">Mật khẩu *</label>
                        <input asp-for="Password" type="password" placeholder="Tối thiểu 6 ký tự" required />
                        <span asp-validation-for="Password" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label asp-for="ConfirmPassword">Xác nhận mật khẩu *</label>
                        <input asp-for="ConfirmPassword" type="password" placeholder="Nhập lại mật khẩu" required />
                        <span asp-validation-for="ConfirmPassword" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                    </div>
                </div>

                <div class="form-group" style="margin-top: 12px;">
                    <label style="font-weight: normal; cursor: pointer; display: flex; align-items: flex-start; gap: 8px;">
                        <input type="checkbox" required style="width: auto; margin-top: 4px;" />
                        <span>Tôi đồng ý với <a href="#" style="color: var(--primary); font-weight: bold;">Điều khoản sử dụng</a> và <a href="#" style="color: var(--primary); font-weight: bold;">Chính sách bảo mật</a></span>
                    </label>
                </div>

                <button type="submit" class="btn btn-primary btn-full btn-lg" style="margin-top: 16px;">
                    Đăng ký tài khoản
                </button>
            </form>

            <div class="auth-footer">
                Đã có tài khoản? <a asp-action="Login">Đăng nhập</a>
            </div>
        </div>
    </div>
</body>
</html>
