@model Tuan6.Models.Category
@{
    ViewData["Title"] = "Xác nhận xóa Danh mục";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow border-0 rounded-3">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 4rem;"></i>
                    <h3 class="card-title fw-bold text-danger mt-3">Xác nhận xóa danh mục?</h3>
                </div>

                <div class="alert alert-warning p-4 border border-warning rounded-3 mb-4">
                    <h5 class="fw-bold"><i class="bi bi-info-circle-fill"></i> CẢNH BÁO QUAN TRỌNG:</h5>
                    <p class="mb-0">Xóa danh mục <strong>"@Model.Name"</strong> sẽ tự động xóa tất cả các sản phẩm thuộc danh mục này.</p>
                </div>

                <div class="bg-light p-4 rounded-3 border mb-4">
                    <div class="row">
                        <div class="col-sm-4 text-muted fw-bold">Mã danh mục:</div>
                        <div class="col-sm-8 fw-bold">@Model.Id</div>
                    </div>
                    <hr>
                    <div class="row">
                        <div class="col-sm-4 text-muted fw-bold">Tên danh mục:</div>
                        <div class="col-sm-8 fw-bold">@Model.Name</div>
                    </div>
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-between gap-3">
                        <a asp-action="Index" class="btn btn-outline-secondary w-50 py-2 rounded-pill fw-bold">Hủy bỏ</a>
                        <button type="submit" class="btn btn-danger w-50 py-2 rounded-pill fw-bold shadow-sm">Đồng ý xóa</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
