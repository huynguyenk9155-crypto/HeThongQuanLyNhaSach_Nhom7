@model Tuan6.Models.Category
@{
    ViewData["Title"] = "Xác nhận xóa Danh mục";
}

<header class="admin-header">
    <div class="page-title">
        <h2>🗑️ Xác nhận xóa Danh mục</h2>
        <p>Hành động này không thể hoàn tác và sẽ ảnh hưởng trực tiếp đến các cuốn sách liên quan.</p>
    </div>
    <div class="header-right">
        <a asp-action="Index" class="btn btn-secondary btn-sm">↩ Quay lại</a>
    </div>
</header>

<div class="admin-content">
    <div class="data-table-card" style="padding: 32px; max-width: 600px; margin: 0 auto; text-align: center;">
        <div style="font-size: 64px; color: var(--danger); margin-bottom: 16px;">⚠️</div>
        <h3 style="margin-bottom: 16px; color: var(--danger);">CẢNH BÁO QUAN TRỌNG:</h3>
        
        <div style="background: #fff8f8; border: 1px solid #ffcccc; color: #cc0000; padding: 16px; border-radius: var(--radius); font-size: 14px; margin-bottom: 24px; text-align: left; line-height: 1.6;">
            <strong>Lưu ý:</strong> Việc xóa danh mục <strong>"@Model.Name"</strong> sẽ tự động xóa tất cả các sản phẩm/cuốn sách thuộc danh mục này trong cơ sở dữ liệu.
        </div>

        <div style="background: var(--gray-100); padding: 24px; border-radius: var(--radius); text-align: left; margin-bottom: 32px; line-height: 2;">
            <div><strong>Mã danh mục:</strong> #DM-@Model.Id.ToString("D3")</div>
            <div><strong>Tên danh mục:</strong> @Model.Name</div>
        </div>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div style="display: flex; gap: 12px;">
                <button type="submit" class="btn btn-danger btn-lg" style="flex: 1; justify-content: center;">
                    🗑 Đồng ý xóa
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg" style="flex: 1; justify-content: center;">
                    Hủy bỏ
                </a>
            </div>
        </form>
    </div>
</div>
