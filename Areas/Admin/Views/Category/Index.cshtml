@model IEnumerable<Tuan6.Models.Category>
@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<header class="admin-header">
    <div class="page-title">
        <h2>📂 Quản lý danh mục thể loại</h2>
        <p>Quản lý các danh mục phân loại sách của hệ thống</p>
    </div>
    <div class="header-right">
        <a asp-action="Create" class="btn btn-primary btn-sm">➕ Thêm danh mục mới</a>
    </div>
</header>

<div class="admin-content">
    <div class="data-table-card">
        <div class="data-table-header">
            <h4>Danh sách Danh mục (@Model.Count())</h4>
            <div class="data-table-actions">
                <input type="text" id="categorySearch" placeholder="🔍 Tìm kiếm danh mục...">
            </div>
        </div>
        <table class="data-table" id="categoriesTable">
            <thead>
                <tr>
                    <th style="width: 100px;">Mã</th>
                    <th>Tên Danh mục</th>
                    <th style="width: 150px; text-align: right; padding-right: 24px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr class="category-row">
                            <td><strong>#DM-@item.Id.ToString("D3")</strong></td>
                            <td><strong style="color: var(--dark);">@item.Name</strong></td>
                            <td style="padding-right: 24px;">
                                <div class="action-btns" style="justify-content: flex-end;">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn edit" title="Sửa">✏️</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn delete" title="Xóa">🗑</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" style="text-align: center; color: var(--gray-500); padding: 32px;">Chưa có danh mục nào. Hãy tạo mới.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('categorySearch').addEventListener('input', function() {
            var val = this.value.toLowerCase().trim();
            var rows = document.querySelectorAll('.category-row');
            rows.forEach(function(row) {
                var text = row.textContent.toLowerCase();
                if (text.indexOf(val) > -1) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
}
