@model IEnumerable<Tuan6.Models.Category>
@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h2 class="text-primary fw-bold">Danh sách Danh mục</h2>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
        <i class="bi bi-plus-circle"></i> Thêm mới danh mục
    </a>
</div>

<div class="card shadow border-0 rounded-3">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0 align-middle">
            <thead class="table-primary text-white">
                <tr>
                    <th scope="col" class="py-3 ps-4" style="width: 10%">Mã</th>
                    <th scope="col" class="py-3">Tên Danh mục</th>
                    <th scope="col" class="py-3 text-end pe-4" style="width: 30%">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-muted">@item.Id</td>
                            <td class="fw-bold">@item.Name</td>
                            <td class="text-end pe-4">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning rounded-pill px-3 me-2">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-pill px-3">Xóa</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center py-4 text-muted">Chưa có danh mục nào. Hãy tạo mới.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-4">
    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
        Quản lý Sản phẩm
    </a>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
