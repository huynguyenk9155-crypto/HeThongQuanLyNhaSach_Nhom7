@model Tuan6.Models.Category
@{
    ViewData["Title"] = "Chỉnh sửa Danh mục";
}

<header class="admin-header">
    <div class="page-title">
        <h2>✏️ Chỉnh sửa Danh mục</h2>
        <p>Cập nhật tên danh mục thể loại sách trong hệ thống</p>
    </div>
    <div class="header-right">
        <a asp-action="Index" class="btn btn-secondary btn-sm">↩ Quay lại</a>
    </div>
</header>

<div class="admin-content">
    <div class="data-table-card" style="padding: 32px; max-width: 600px; margin: 0 auto;">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" style="color: var(--danger); font-size: 14px; margin-bottom: 20px;"></div>

            <div class="form-group">
                <label asp-for="Name">Tên danh mục *</label>
                <input asp-for="Name" placeholder="Nhập tên danh mục thể loại" required />
                <span asp-validation-for="Name" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
            </div>

            <div style="margin-top: 32px; display: flex; gap: 12px;">
                <button type="submit" class="btn btn-primary btn-lg" style="flex: 1; justify-content: center;">
                    💾 Cập nhật
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg" style="justify-content: center;">
                    Hủy bỏ
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
