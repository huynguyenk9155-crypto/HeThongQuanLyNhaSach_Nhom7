@model Tuan6.Models.Book
@{
    ViewData["Title"] = "Xóa sách";
}

<header class="admin-header">
    <div class="page-title">
        <h2>🗑️ Xác nhận xóa đầu sách</h2>
        <p>Hành động này không thể hoàn tác. Vui lòng xác nhận trước khi thực hiện.</p>
    </div>
    <div class="header-right">
        <a asp-action="Index" class="btn btn-secondary btn-sm">↩ Quay lại</a>
    </div>
</header>

<div class="admin-content">
    <div class="data-table-card" style="padding: 32px; max-width: 600px; margin: 0 auto; text-align: center;">
        <div style="font-size: 64px; color: var(--danger); margin-bottom: 16px;">⚠️</div>
        <h3 style="margin-bottom: 24px;">Xác nhận xóa cuốn sách?</h3>
        
        <div style="background: var(--gray-100); padding: 24px; border-radius: var(--radius); text-align: left; margin-bottom: 32px; line-height: 2;">
            <div><strong>Tên sách:</strong> @Model.Title</div>
            <div><strong>Tác giả:</strong> @Model.Author</div>
            <div><strong>Danh mục:</strong> @(Model.Category?.Name ?? "N/A")</div>
            <div><strong>Giá bán:</strong> @Model.Price.ToString("N0")đ</div>
            <div><strong>Số lượng tồn:</strong> @Model.StockQuantity</div>
        </div>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div style="display: flex; gap: 12px;">
                <button type="submit" class="btn btn-danger btn-lg" style="flex: 1; justify-content: center;">
                    🗑 Xóa vĩnh viễn
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg" style="flex: 1; justify-content: center;">
                    Hủy bỏ
                </a>
            </div>
        </form>
    </div>
</div>
