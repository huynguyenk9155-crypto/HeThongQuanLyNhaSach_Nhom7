@model Tuan6.Models.Book
@{
    ViewData["Title"] = "Chỉnh sửa sách";
}

<header class="admin-header">
    <div class="page-title">
        <h2>✏️ Chỉnh sửa thông tin sách</h2>
        <p>Cập nhật thông tin chi tiết cho cuốn sách: <strong>@Model.Title</strong></p>
    </div>
    <div class="header-right">
        <a asp-action="Index" class="btn btn-secondary btn-sm">↩ Quay lại</a>
    </div>
</header>

<div class="admin-content">
    <div class="data-table-card" style="padding: 32px; max-width: 800px; margin: 0 auto;">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div style="background: #f8d7da; color: #721c24; padding: 16px; border-radius: var(--radius); margin-bottom: 20px; font-size: 14px;">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <div class="form-group">
                <label asp-for="Title">Tên sách *</label>
                <input asp-for="Title" placeholder="Nhập tên sách" required />
                <span asp-validation-for="Title" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
            </div>

            <div class="form-row">
                <div class="form-group" style="flex: 1;">
                    <label asp-for="AuthorId">Tác giả *</label>
                    <select asp-for="AuthorId" asp-items="ViewBag.Authors" style="width: 100%; padding: 12px 16px; border: 2px solid var(--gray-300); border-radius: var(--radius); outline: none; font-size: 14px;" required>
                        <option value="">Chọn tác giả</option>
                    </select>
                    <span asp-validation-for="AuthorId" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label asp-for="CategoryId">Danh mục *</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" style="width: 100%; padding: 12px 16px; border: 2px solid var(--gray-300); border-radius: var(--radius); outline: none; font-size: 14px;" required>
                        <option value="">Chọn danh mục</option>
                    </select>
                    <span asp-validation-for="CategoryId" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="PublisherId">Nhà xuất bản</label>
                <select asp-for="PublisherId" asp-items="ViewBag.Publishers" style="width: 100%; padding: 12px 16px; border: 2px solid var(--gray-300); border-radius: var(--radius); outline: none; font-size: 14px;">
                    <option value="">Chọn nhà xuất bản (Không bắt buộc)</option>
                </select>
                <span asp-validation-for="PublisherId" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
            </div>

            <div class="form-row">
                <div class="form-group" style="flex: 1;">
                    <label asp-for="Price">Giá bán (đ) *</label>
                    <input asp-for="Price" type="number" min="1000" placeholder="Ví dụ: 79000" required />
                    <span asp-validation-for="Price" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label asp-for="StockQuantity">Số lượng tồn kho *</label>
                    <input asp-for="StockQuantity" type="number" min="0" placeholder="Ví dụ: 100" required />
                    <span asp-validation-for="StockQuantity" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>
            </div>

            <div class="form-group" style="display: flex; gap: 16px; align-items: center; background: var(--gray-100); padding: 16px; border-radius: var(--radius);">
                <div style="width: 60px; height: 80px; background: var(--gray-300); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0;">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" style="width: 100%; height: 100%; object-fit: cover;" />
                    }
                    else
                    {
                        <span style="font-size: 24px;">📕</span>
                    }
                </div>
                <div style="flex: 1;">
                    <label>Thay đổi hình ảnh đại diện</label>
                    <input type="file" name="imageFile" accept="image/*" style="padding: 10px 0 0;" />
                </div>
            </div>

            <div class="form-group" style="margin-top: 20px;">
                <label asp-for="Description">Mô tả sách</label>
                <textarea asp-for="Description" rows="6" placeholder="Nhập mô tả tóm tắt nội dung cuốn sách..." style="width: 100%; padding: 12px 16px; border: 2px solid var(--gray-300); border-radius: var(--radius); font-size: 15px; outline: none; transition: var(--transition); resize: vertical;"></textarea>
                <span asp-validation-for="Description" style="color: var(--danger); font-size: 12px; display: block; margin-top: 4px;"></span>
            </div>

            <div style="margin-top: 32px; display: flex; gap: 12px;">
                <button type="submit" class="btn btn-primary btn-lg" style="flex: 1; justify-content: center;">
                    💾 Lưu thay đổi
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg" style="justify-content: center;">
                    Hủy bỏ
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
