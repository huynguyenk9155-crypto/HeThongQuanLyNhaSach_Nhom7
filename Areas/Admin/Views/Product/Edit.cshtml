@model Tuan6.Models.Product
@{
    ViewData["Title"] = "Cập nhật Sản phẩm";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow border-0 rounded-3">
            <div class="card-body p-5">
                <h3 class="card-title text-center mb-4 fw-bold text-primary">Cập nhật Sản phẩm</h3>
                
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ImageUrl" />
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Name" class="form-control border-top-0 border-end-0 border-start-0 rounded-0" placeholder="Tên sản phẩm" />
                        <label asp-for="Name">Tên sản phẩm</label>
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <select asp-for="CategoryId" class="form-select border-top-0 border-end-0 border-start-0 rounded-0" asp-items="ViewBag.Categories">
                            <option value="">-- Chọn Danh mục --</option>
                        </select>
                        <label asp-for="CategoryId">Danh mục sản phẩm</label>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Price" type="number" class="form-control border-top-0 border-end-0 border-start-0 rounded-0" placeholder="Giá bán" />
                        <label asp-for="Price">Giá bán (đ)</label>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <textarea asp-for="Description" class="form-control border-top-0 border-end-0 border-start-0 rounded-0" style="height: 100px;" placeholder="Mô tả sản phẩm"></textarea>
                        <label asp-for="Description">Mô tả sản phẩm</label>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-2">
                                <label class="form-label text-muted d-block">Hình ảnh hiện tại</label>
                                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-thumbnail" style="max-height: 150px;" />
                            </div>
                        }
                        <label for="imageFile" class="form-label text-muted">Thay đổi hình ảnh sản phẩm</label>
                        <input type="file" name="imageFile" id="imageFile" class="form-control rounded-pill" accept="image/*" />
                    </div>

                    <div class="d-flex justify-content-between gap-3">
                        <a asp-action="Index" class="btn btn-outline-secondary w-50 py-2 rounded-pill fw-bold">Hủy</a>
                        <button type="submit" class="btn btn-primary w-50 py-2 rounded-pill fw-bold shadow-sm">Cập nhật</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
