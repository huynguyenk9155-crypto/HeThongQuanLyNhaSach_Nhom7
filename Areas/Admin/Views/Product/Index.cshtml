@model IEnumerable<Tuan6.Models.Product>
@{
    ViewData["Title"] = "Quản lý Sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h2 class="text-primary fw-bold">Danh sách Sản phẩm</h2>
    <div class="d-flex gap-2">
        <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            Quản lý Danh mục
        </a>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-circle"></i> Thêm mới sản phẩm
        </a>
    </div>
</div>

<div class="card shadow border-0 rounded-3">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0 align-middle">
            <thead class="table-primary text-white">
                <tr>
                    <th scope="col" class="py-3 ps-4" style="width: 10%">Hình ảnh</th>
                    <th scope="col" class="py-3">Tên sản phẩm</th>
                    <th scope="col" class="py-3">Danh mục</th>
                    <th scope="col" class="py-3">Giá bán</th>
                    <th scope="col" class="py-3 text-end pe-4" style="width: 25%">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name" class="rounded" style="width: 60px; height: 60px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center border" style="width: 60px; height: 60px;">
                                        <i class="bi bi-image text-muted" style="font-size: 1.5rem;"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="fw-bold">@item.Name</div>
                                <div class="text-muted small text-truncate" style="max-width: 300px;">@item.Description</div>
                            </td>
                            <td>
                                <span class="badge bg-secondary">@(item.Category?.Name ?? "N/A")</span>
                            </td>
                            <td class="fw-bold text-success">@item.Price.ToString("N0") đ</td>
                            <td class="text-end pe-4">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning rounded-pill px-3 me-2">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-pill px-3">Xóa</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">Chưa có sản phẩm nào. Hãy tạo mới.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
