@model Tuan6.Models.Product
@{
    ViewData["Title"] = "Xác nhận xóa Sản phẩm";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow border-0 rounded-3">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 4rem;"></i>
                    <h3 class="card-title fw-bold text-danger mt-3">Xác nhận xóa sản phẩm?</h3>
                    <p class="text-muted">Hành động này không thể hoàn tác.</p>
                </div>

                <div class="bg-light p-4 rounded-3 border mb-4">
                    <div class="d-flex align-items-center gap-4">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.Name" class="rounded border" style="width: 100px; height: 100px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-light rounded d-flex align-items-center justify-content-center border" style="width: 100px; height: 100px;">
                                <i class="bi bi-image text-muted" style="font-size: 2rem;"></i>
                            </div>
                        }
                        <div>
                            <h5 class="fw-bold mb-1">@Model.Name</h5>
                            <span class="badge bg-secondary mb-2">@(Model.Category?.Name ?? "N/A")</span>
                            <div class="fw-bold text-success">@Model.Price.ToString("N0") đ</div>
                        </div>
                    </div>
                    <hr>
                    <div class="row">
                        <div class="col-sm-3 text-muted fw-bold">Mô tả:</div>
                        <div class="col-sm-9">@Model.Description</div>
                    </div>
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-between gap-3">
                        <a asp-action="Index" class="btn btn-outline-secondary w-50 py-2 rounded-pill fw-bold">Hủy bỏ</a>
                        <button type="submit" class="btn btn-danger w-50 py-2 rounded-pill fw-bold shadow-sm">Đồng ý xóa</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
